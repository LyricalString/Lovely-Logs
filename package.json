{
  "name": "lovely-logs",
  "version": "1.0.2",
  "description": "Lovely console logs for website development on NodeJS. Supports colors, timestamps, and more.",
  "main": "build/index.js",
  "scripts": {
    "test": "jest --config jestconfig.json",
    "build": "tsc",
    "build:watch": "tsc -w",
    "start": "node build/index.js",
    "start:watch": "nodemon build/index.js",
    "prepare": "npm run build",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "fancy logs",
    "console log",
    "pretty console logs",
    "pretty logs",
    "fancy console logs",
    "fancy logger",
    "lovely logs",
    "lovely logger",
    "lovely console logs"
  ],
  "author": "LyricalString",
  "license": "MIT",
  "files": [
    "build/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LyricalString/Lovely-Logs.git"
  },
  "homepage": "https://github.com/LyricalString/Lovely-Logs",
  "devDependencies": {
    "@types/jest": "^29.5.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.4"
  }
}
